# =========================================================
# FPGA / Verilog / APIO Project .gitignore
# =========================================================

# ---------------------------------------------------------
# Build Directories
# ---------------------------------------------------------
_build/
build/
dist/
out/

# ---------------------------------------------------------
# APIO
# ---------------------------------------------------------
.apio/

# ---------------------------------------------------------
# Generated FPGA Files
# ---------------------------------------------------------
*.asc
*.bin
*.bit
*.config
*.dfu
*.hex
*.jed
*.json
*.map
*.pnr
*.rpt
*.svf

# ---------------------------------------------------------
# Simulation Files
# ---------------------------------------------------------
*.vcd
*.fst
*.lxt
*.out
*.log
*.dump

# ---------------------------------------------------------
# Verilator
# ---------------------------------------------------------
obj_dir/
*.d
*.o

# ---------------------------------------------------------
# Yosys / nextpnr / Toolchain
# ---------------------------------------------------------
yosys.log
nextpnr.log
icetime.log

# ---------------------------------------------------------
# Temporary Files
# ---------------------------------------------------------
*.tmp
*.temp
*.bak
*.swp
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------
# VSCode
# ---------------------------------------------------------
.vscode/*

# Keep shared project settings
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/extensions.json
!.vscode/launch.json

# ---------------------------------------------------------
# Python
# ---------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.env/

# ---------------------------------------------------------
# C / C++
# ---------------------------------------------------------
*.exe
*.elf
*.a
*.so
*.dll
*.dylib

# ---------------------------------------------------------
# Documentation Build Artifacts
# ---------------------------------------------------------
*.pdf
*.aux
*.toc
*.lof
*.lot

# ---------------------------------------------------------
# Coverage / Analysis
# ---------------------------------------------------------
coverage/
*.gcda
*.gcno
*.info

# ---------------------------------------------------------
# Misc
# ---------------------------------------------------------
.cache/
.history/